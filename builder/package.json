{
  "name": "osint-builder",
  "version": "1.0.0",
  "description": "Triggers Warp cloud agents for OSINT collection via oz-agent-sdk",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "collect": "tsx index.ts",
    "dry-run": "tsx index.ts --dry-run",
    "verify-prompt": "tsx scripts/verify-prompt-extraction.ts",
    "update-prompt-snapshot": "UPDATE_SNAPSHOT=1 tsx scripts/verify-prompt-extraction.ts"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "oz-agent-sdk": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
