        "extraction": {
          "screenshot": "Capture page screenshots",
          "extractText": "Extract text content",
          "extractHTML": "Extract HTML content",
          "extractMetadata": "Extract page metadata",
          "extractLinks": "Extract links from page"
        },
        "session": {
          "createSession": "Create new browser session",
          "closeSession": "Close browser session",
          "getStatus": "Get session status"
        },
        "debug": {
          "getConsoleLogs": "Get page console logs",
          "getErrors": "Get page errors",
          "executeScript": "Execute JavaScript in page"
        }
      },
      "dependencies": [
        "@browserbasehq/sdk"
      ],
      "documentation": {
        "url": "https://docs.browserbase.com",
        "examples": "See skills/agent-browser.ts"
      }
    }
