# Required: Claude API for AI agents (used by the Warp Cloud Agent)
ANTHROPIC_API_KEY=***

# Required for the orchestrator (builder/index.ts) to dispatch Warp agents
WARP_API_KEY=***
WARP_ENVIRONMENT_ID=***

# Optional: Perplexity API for runtime confidence validation
PERPLEXITY_API_KEY=***

# Optional: Twitter API (only needed if any Twitter source uses the API path
# instead of agent-browser scraping)
TWITTER_BEARER_TOKEN=***

# Optional: additional integrations
# OPENAI_API_KEY=***
# BROWSERBASE_API_KEY=***
