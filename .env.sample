# .env.sample
#
# Mirrors the README's "Configuration" table. Keep this file and that
# section in lockstep. See ../README.md for which vars belong in
# GitHub Actions secrets vs. the Warp Cloud Agent environment image.

# ── Orchestrator (read by builder/index.ts on the GH Actions runner) ────
# Required: dispatches Warp Cloud Agents.
WARP_API_KEY=***
WARP_ENVIRONMENT_ID=***

# Required: push token used by each cloud-agent run to commit data back.
# Either name works; OSINT_GH_TOKEN takes precedence over GH_TOKEN.
# Use a fine-grained PAT with `Contents: write` on this repo.
OSINT_GH_TOKEN=***
# GH_TOKEN=***

# ── Cloud Agent runtime (baked into the Warp env image, not this repo) ──
# These don't need to be in your local .env to run the orchestrator —
# they live in the Warp environment image identified by WARP_ENVIRONMENT_ID.
# Listed here so you know what the cloud agent expects to find.

# Required by the agent itself.
ANTHROPIC_API_KEY=***

# Optional: Perplexity API for runtime confidence validation. Degrades
# gracefully when absent.
PERPLEXITY_API_KEY=***

# Optional: Twitter API path. Only needed if a Twitter source explicitly
# uses the API path instead of agent-browser scraping.
TWITTER_BEARER_TOKEN=***

# ── Embeddings workflow (.github/workflows/embeddings.yml) ──────────────
# Required by the build-embeddings job that powers the search UI.
# Configure as a GitHub Actions secret, not here.
OPENAI_API_KEY=***
